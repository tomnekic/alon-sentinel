# =============================================================================
# REQUIRED
# =============================================================================

# PostgreSQL connection string.
DATABASE_URL=postgresql://postgres:secret@localhost/alon_sentinel_db

# AES-256 key for encrypting stored webhook secrets.
# Must be exactly 64 lowercase hex characters (32 bytes).
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET_ENCRYPTION_KEY=replace_with_64_hex_chars


# =============================================================================
# API SERVER
# =============================================================================

# Address and port the HTTP API listens on.
# Default: 127.0.0.1:3000
#API_BIND_ADDRESS=127.0.0.1:3000

# Lifetime of issued access tokens in seconds.
# Default: 3600
#ACCESS_TOKEN_TTL_SECONDS=3600

# Comma-separated list of origins allowed by CORS.
# Default: http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:4173,http://localhost:4173
#CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Set the Secure flag on session cookies. Disable only in local HTTP dev.
# Default: true
#COOKIE_SECURE=true


# =============================================================================
# DATABASE CONNECTION POOL
# =============================================================================

# Shared pool defaults — used by both the API and worker unless overridden below.

# Maximum total connections across all pool users.
# Default: 20
#DB_MAX_CONNECTIONS=20

# Minimum connections kept alive when idle.
# Default: 2
#DB_MIN_CONNECTIONS=2

# Seconds to wait when acquiring a connection before returning an error.
# Default: 5
#DB_ACQUIRE_TIMEOUT_SECONDS=5

# Seconds an idle connection is kept before being closed.
# Default: 600
#DB_IDLE_TIMEOUT_SECONDS=600

# Maximum lifetime of any connection in seconds.
# Default: 1800
#DB_MAX_LIFETIME_SECONDS=1800

# Per-service overrides (fall back to DB_MAX/MIN_CONNECTIONS when unset).
#API_DB_MAX_CONNECTIONS=20
#API_DB_MIN_CONNECTIONS=2
#WORKER_DB_MAX_CONNECTIONS=20
#WORKER_DB_MIN_CONNECTIONS=2


# =============================================================================
# WORKER
# =============================================================================

# Maximum time in milliseconds a worker sleeps between polling for due work.
# Default: 5000
#WORKER_MAX_POLL_INTERVAL_MS=5000

# Number of concurrent site-check worker tasks.
# Default: 3
#SITE_WORKER_COUNT=3

# Maximum concurrent outbound HTTP site checks.
# Default: 10
#MAX_HTTP_CONCURRENT_CHECKS=10

# Number of due sites fetched per polling batch.
# Default: 100
#DUE_SITES_BATCH_SIZE=100

# How long (in seconds) a worker holds a lease on a site check before it is
# considered abandoned and can be retried by another worker.
# Default: 60
#LEASE_SITE_CHECK_SECONDS=60


# =============================================================================
# HTTP CHECK BEHAVIOUR
# =============================================================================

# Per-request timeout in seconds for outbound site checks.
# Default: 10
#HTTP_CHECK_TIMEOUT_SECONDS=10

# Maximum response body bytes read during a check (excess is discarded).
# Default: 65536
#HTTP_CHECK_MAX_RESPONSE_BODY_BYTES=65536

# Total attempts per check, including the initial try.
# Default: 3
#HTTP_CHECK_MAX_ATTEMPTS=3

# Comma-separated wait times in milliseconds between successive retry attempts.
# Must provide at least (HTTP_CHECK_MAX_ATTEMPTS - 1) values.
# Default: 1000,3000
#HTTP_CHECK_RETRY_DELAYS_MS=1000,3000

# Random jitter added to each retry delay, expressed as a percentage (0–100).
# Default: 20
#HTTP_CHECK_RETRY_JITTER_PERCENT=20


# =============================================================================
# DATA RETENTION
# =============================================================================

# Number of days to keep site monitor check records.
# Default: 90
#SITE_MONITOR_CHECK_RETENTION_DAYS=90

# How often (in seconds) the retention cleanup job runs.
# Default: 3600
#SITE_MONITOR_CHECK_RETENTION_INTERVAL_SECONDS=3600

# Maximum records deleted per retention cleanup run.
# Default: 5000
#SITE_MONITOR_CHECK_RETENTION_BATCH_SIZE=5000


# =============================================================================
# NOTIFICATIONS
# =============================================================================

# Number of due notifications fetched per polling batch.
# Default: 100
#DUE_NOTIFICATION_BATCH_SIZE=100

# Maximum concurrent outbound notification deliveries.
# Default: 10
#MAX_NOTIFICATION_CONCURRENT_DELIVERIES=10

# How long (in seconds) a worker holds a lease on a notification delivery
# before it is considered abandoned and can be retried.
# Default: 60
#LEASE_NOTIFICATION_DELIVERY_SECONDS=60

# Per-delivery HTTP timeout in seconds.
# Default: 10
#NOTIFICATION_DELIVERY_TIMEOUT_SECONDS=10

# Maximum delivery attempts before a notification is marked as failed.
# Default: 5
#NOTIFICATION_MAX_ATTEMPTS=5

# Base delay in seconds for exponential back-off between delivery retries.
# Default: 30
#NOTIFICATION_RETRY_BASE_SECONDS=30


# =============================================================================
# AUTH RATE LIMITING
# =============================================================================

# Maximum login attempts allowed within the rate-limit window.
# Default: 10
#AUTH_RATE_LIMIT_MAX_REQUESTS=10

# Length of the rate-limit window in seconds.
# Default: 60
#AUTH_RATE_LIMIT_WINDOW_SECONDS=60


# =============================================================================
# REVERSE PROXY
# =============================================================================

# Set to true only when all requests arrive through a trusted reverse proxy
# that sets X-Forwarded-For. TRUSTED_PROXY_IPS must also be set.
# Default: false
#TRUST_PROXY_HEADERS=false

# Comma-separated list of trusted proxy IP addresses.
# Required when TRUST_PROXY_HEADERS=true.
#TRUSTED_PROXY_IPS=127.0.0.1


# =============================================================================
# SMTP  (email notifications — leave SMTP_HOST unset to disable)
# =============================================================================

# SMTP server hostname. Omit or leave blank to disable email delivery.
#SMTP_HOST=smtp.example.com

# SMTP port. Default: 587
#SMTP_PORT=587

# SMTP credentials (optional — omit for unauthenticated relays).
#SMTP_USERNAME=alerts@example.com
#SMTP_PASSWORD=replace_with_smtp_password

# Sender address — required when SMTP_HOST is set.
#SMTP_FROM_EMAIL=alerts@example.com

# Optional display name shown in the From header.
#SMTP_FROM_NAME=Alon Sentinel


# =============================================================================
# LOGGING  (can also be passed as CLI flags --log-dir / --log-level)
# =============================================================================

# Directory where log files are written.
# Default: ./logs
#LOG_DIR=./logs

# Minimum log level: trace | debug | info | warn | error
# Default: info
#LOG_LEVEL=info
