# URL of the alon_sentinel API backend.
# Used by the Vite dev server proxy so that requests to /v1/* are forwarded
# to the backend during development. Copy this file to .env and adjust if
# your backend runs on a different address or port.
VITE_SENTINEL_API_BASE_URL=http://127.0.0.1:3000

# Show demo credentials on the login screen (build-time flag, default false).
# VITE_SHOW_DEMO_ACCOUNT=false
