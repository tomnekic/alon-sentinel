# Copy to .env and adjust before running.
# All values below are the defaults — override only what you need.

# ── Postgres (Alon) ──────────────────────────────────────────────────────────
DB_PASSWORD=benchpw

# ── Alon API ─────────────────────────────────────────────────────────────────
# 64-hex-char AES-256 key — change in any shared environment
WEBHOOK_SECRET_KEY=6f1653057b08ef82d0f760eb3669e6ba84356d7f647f0023be5c28005c1d11d6

ALON_ADMIN_EMAIL=bench@bench.local
ALON_ADMIN_PASSWORD=Bench1234!

# Number of background site-check workers
ALON_WORKER_COUNT=3

# ── Uptime Kuma ──────────────────────────────────────────────────────────────
KUMA_ADMIN_USER=bench
KUMA_ADMIN_PASSWORD=Bench1234!

# ── Benchmark parameters ─────────────────────────────────────────────────────
# How many HTTP monitors to seed into each tool
MONITOR_COUNT=50

# Check interval in seconds (applied to both tools)
CHECK_INTERVAL=60

# How long to collect worker throughput data (seconds)
MEASURE_DURATION=300
